{
  "name": "@metacubexd/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./kernel/assets": {
      "types": "./src/kernel/assets.ts",
      "import": "./src/kernel/assets.ts"
    },
    "./kernel/fetch-kernel": {
      "types": "./src/kernel/fetch-kernel.ts",
      "import": "./src/kernel/fetch-kernel.ts"
    },
    "./kernel/fetch-wintun": {
      "types": "./src/kernel/fetch-wintun.ts",
