{
  "name": "@metacubexd/ui",
  "version": "1.270.2",
  "description": "Mihomo Dashboard, The Official One, XD",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:mock": "MOCK_MODE=true nuxt build",
    "dev": "nuxt dev --host",
    "dev:mock": "MOCK_MODE=true nuxt dev --host",
    "format": "pnpm prettier --write --ignore-unknown .",
    "generate": "nuxt generate",
    "generate:mock": "MOCK_MODE=true nuxt generate",
    "generate:desktop": "NUXT_APP_BASE_URL=./ MCXD_DISABLE_PWA=true nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint --fix .",
    "preview": "nuxt preview --host",
    "screenshot": "tsx scripts/screenshot.ts",
    "test:e2e": "vitest run e2e/",
    "test:unit": "vitest run --exclude='e2e/**'",
    "test:coverage": "vitest run --coverage --exclude='e2e/**'",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@metacubexd/config-editor": "workspace:*",
    "@floating-ui/vue": "catalog:",
    "@nuxt/fonts": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@nuxtjs/tailwindcss": "catalog:",
    "@pinia/nuxt": "catalog:",
    "@tabler/icons-vue": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/vue-query": "catalog:",
    "@tanstack/vue-virtual": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/integrations": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "byte-size": "catalog:",
    "d3": "catalog:",
    "daisyui": "catalog:",
    "dayjs": "catalog:",
    "highcharts": "catalog:",
    "ky": "catalog:",
    "markdown-it": "catalog:",
    "match-sorter": "catalog:",
    "meta-json-schema": "catalog:",
    "monaco-editor": "catalog:",
    "monaco-yaml": "catalog:",
    "nuxt": "catalog:",
    "pinia": "catalog:",
    "sortablejs": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "uqr": "catalog:",
    "vite": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vue-sonner": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@playwright/test": "catalog:",
    "@prettier/plugin-oxc": "catalog:",
    "@types/byte-size": "catalog:",
    "@types/d3": "catalog:",
    "@types/markdown-it": "catalog:",
    "@types/node": "catalog:",
    "@types/sortablejs": "catalog:",
    "@vite-pwa/nuxt": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "sort-package-json": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
